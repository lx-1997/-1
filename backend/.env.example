# Local development can use mock mode without a cloud key.
# Set to openai, minimax, or openai-compatible when connecting a real model.
DEEPFOCUS_LLM_PROVIDER=mock

# OpenAI or OpenAI-compatible cloud model.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# MiniMax uses an OpenAI-compatible endpoint.
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_BASE_URL=https://api.minimax.io/v1

# Frontend dev server origin. Use * for local prototypes only.
CORS_ORIGINS=http://localhost:3000

# Optional free market-data keys. Finnhub is tried first for quotes, then Alpha Vantage.
# Earnings calendar tries Nasdaq's public no-key calendar first, then Alpha Vantage
# when configured.
# Without keys quotes fall back to a no-key public snapshot source when reachable,
# while the earnings calendar returns watchlist templates only for symbols not found
# in the public calendar window.
FINNHUB_API_KEY=
ALPHAVANTAGE_API_KEY=
NASDAQ_EARNINGS_SCAN_DAYS=60
EARNINGS_CACHE_TTL_SECONDS=1800

# Optional: Xueqiu authenticated requests for keyword crawl.
# Compatible with pysnowball/snowball-mcp style tokens.
# Use a single-line Cookie value from your own authorized Xueqiu session.
# Do not use token pools or automated CAPTCHA/WAF solving.
DEEPFOCUS_XUEQIU_COOKIE=
# Optional: paste the User-Agent from the same logged-in browser session.
DEEPFOCUS_XUEQIU_USER_AGENT=
# Optional: paste the Referer from the copied browser request.
DEEPFOCUS_XUEQIU_REFERER=
# Optional: copied /query/v1/search/status.json URL with the temporary md5 parameter.
DEEPFOCUS_XUEQIU_STATUS_URL=
# Alternative env name also supported:
# XUEQIU_TOKEN=xq_a_token=xxxxx;u=xxxx
